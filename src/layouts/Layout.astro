---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Bespoke web design in Southampton, serving the UK. Design-led websites without the agency headaches. Almost two decades of graphic design expertise." } = Astro.props;

const siteUrl = "https://kombu.uk";
const siteName = "Kombu Web Design";
const ogImage = `${siteUrl}/images/og-image.jpg?v=2`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google tag (gtag.js) - GA4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-5H2CJESBZ0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5H2CJESBZ0');
    </script>

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Ryan" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={siteUrl} />

    <!-- Geo Meta Tags -->
    <meta name="geo.region" content="GB-HAM" />
    <meta name="geo.placename" content="Southampton" />
    <meta name="geo.position" content="50.9097;-1.4044" />
    <meta name="ICBM" content="50.9097, -1.4044" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Kombu Web Design - Bespoke websites in Southampton, UK" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={siteUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Kombu Web Design - Bespoke websites in Southampton, UK" />

    <!-- Theme & PWA -->
    <meta name="theme-color" content="#1A1412" />
    <meta name="msapplication-TileColor" content="#1A1412" />

    <!-- PWA: web-app manifest enables "Install / Add to Home Screen" -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="application-name" content="Kombu" />

    <!-- iOS standalone web-app behaviour (no Safari chrome when launched from home screen) -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Kombu" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts preload -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="dns-prefetch" href="https://api.fontshare.com" />

    <!-- JSON-LD: LocalBusiness + ProfessionalService -->
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://kombu.uk/#website",
          "url": "https://kombu.uk",
          "name": "Kombu Web Design",
          "description": "Bespoke web design in Southampton, serving the UK",
          "publisher": {
            "@id": "https://kombu.uk/#business"
          },
          "inLanguage": "en-GB"
        },
        {
          "@type": "WebPage",
          "@id": "https://kombu.uk/#webpage",
          "url": "https://kombu.uk",
          "name": "Kombu Web Design | Bespoke Websites That Work As Hard As You Do",
          "isPartOf": {
            "@id": "https://kombu.uk/#website"
          },
          "about": {
            "@id": "https://kombu.uk/#business"
          },
          "description": "Bespoke web design in Southampton, serving the UK. Design-led websites without the agency headaches. Almost two decades of graphic design expertise.",
          "inLanguage": "en-GB"
        },
        {
          "@type": ["ProfessionalService", "LocalBusiness"],
          "@id": "https://kombu.uk/#business",
          "name": "Kombu Web Design",
          "alternateName": "Kombu",
          "description": "Bespoke web design and development based in Southampton, serving small businesses across the UK. Design-led websites without the agency headaches, with personal, face-to-face service.",
          "url": "https://kombu.uk",
          "telephone": "+442381112819",
          "email": "design@kombu.uk",
          "image": "https://kombu.uk/images/ryan-stanikk.jpg",
          "logo": "https://kombu.uk/favicon-512.png",
          "priceRange": "££",
          "currenciesAccepted": "GBP",
          "paymentAccepted": "Bank Transfer",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Southampton",
            "addressRegion": "Hampshire",
            "addressCountry": "GB",
            "postalCode": "SO"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": 50.9097,
            "longitude": -1.4044
          },
          "founder": {
            "@type": "Person",
            "@id": "https://kombu.uk/#person",
            "name": "Ryan",
            "jobTitle": "Web Designer & Developer",
            "description": "Designer and commercial photographer with almost two decades of design and marketing expertise, specialising in bespoke web design for small businesses.",
            "image": "https://kombu.uk/images/ryan-stanikk.jpg",
            "url": "https://kombu.uk",
            "sameAs": [
              "https://uk.linkedin.com/in/ryanstanikk",
              "https://www.instagram.com/ryanstanikkphotography/",
              "https://medium.com/@ryanstanikkphotography",
              "https://ryanstanikk.co.uk"
            ],
            "knowsAbout": ["Web Design", "Graphic Design", "Commercial Photography", "Web Development", "Marketing", "SEO"]
          },
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Web Design Services",
            "itemListElement": [
              {
                "@type": "Offer",
                "name": "Starter",
                "price": "49",
                "priceCurrency": "GBP",
                "priceSpecification": {
                  "@type": "UnitPriceSpecification",
                  "price": "49",
                  "priceCurrency": "GBP",
                  "unitText": "MONTH",
                  "billingDuration": "P12M"
                },
                "itemOffered": {
                  "@type": "Service",
                  "name": "Starter Web Design",
                  "description": "Custom single-page website design, mobile-first and responsive, with SEO foundations, hosting, SSL, and ongoing support included."
                }
              },
              {
                "@type": "Offer",
                "name": "Business",
                "price": "79",
                "priceCurrency": "GBP",
                "priceSpecification": {
                  "@type": "UnitPriceSpecification",
                  "price": "79",
                  "priceCurrency": "GBP",
                  "unitText": "MONTH",
                  "billingDuration": "P12M"
                },
                "itemOffered": {
                  "@type": "Service",
                  "name": "Business Web Design",
                  "description": "Multi-page website with up to 5 custom pages, contact forms, Google Business integration, and priority support."
                }
              },
              {
                "@type": "Offer",
                "name": "Growth",
                "price": "129",
                "priceCurrency": "GBP",
                "priceSpecification": {
                  "@type": "UnitPriceSpecification",
                  "price": "129",
                  "priceCurrency": "GBP",
                  "unitText": "MONTH",
                  "billingDuration": "P12M"
                },
                "itemOffered": {
                  "@type": "Service",
                  "name": "Growth Web Application",
                  "description": "Custom web applications with e-commerce, payments, CMS integration, and dedicated support."
                }
              }
            ]
          },
          "areaServed": [
            {
              "@type": "City",
              "name": "Southampton",
              "containedInPlace": {
                "@type": "AdministrativeArea",
                "name": "Hampshire"
              }
            },
            {
              "@type": "Country",
              "name": "United Kingdom"
            }
          ],
          "serviceType": ["Web Design", "Web Development", "Web Apps", "Hosting", "Domain Registration", "Content Management"],
          "knowsAbout": ["Web Design", "Responsive Design", "SEO", "Graphic Design", "Commercial Photography", "Web Development"],
          "sameAs": [
            "https://uk.linkedin.com/in/ryanstanikk",
            "https://www.instagram.com/ryanstanikkphotography/",
            "https://medium.com/@ryanstanikkphotography",
            "https://wa.me/442381112819",
            "https://ryanstanikk.co.uk"
          ]
        },
        {
          "@type": "FAQPage",
          "@id": "https://kombu.uk/#faq",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "How much does a website cost?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Starter websites from £49 per month or £499 one-off, Business sites from £79 per month or £999 one-off, Growth packages from £129 per month. All plans include hosting, SSL, domain setup, and ongoing support with no hidden fees."
              }
            },
            {
              "@type": "Question",
              "name": "How long does it take to build a website?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "A typical single-page site can be ready in 1 to 2 weeks. Larger multi-page sites or sites with custom features may take 3 to 6 weeks. I will give you a realistic timeline during our initial conversation."
              }
            },
            {
              "@type": "Question",
              "name": "Do I need to provide content and images?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "I take in everything you have: documents, existing websites, social media, images, videos. As a commercial photographer, I can also create imagery for your site. I will work with whatever materials you have and fill in the gaps."
              }
            },
            {
              "@type": "Question",
              "name": "Do you handle hosting and domains?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. Domain registration, hosting, SSL, ongoing maintenance. It is all included in your plan. You own everything, there is no lock-in, and I handle every technical detail so you do not have to."
              }
            }
          ]
        }
      ]
    }
    </script>
  </head>
  <body>
    <script is:inline>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      if (window.location.hash) history.replaceState(null, '', window.location.pathname);
      window.scrollTo(0, 0);
    </script>
    <slot />

    <!-- GSAP -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script is:inline src="https://unpkg.com/lenis@1/dist/lenis.min.js"></script>

    <!-- Register the service worker so Android Chrome marks the site
         as installable. iOS uses the manifest alone for Add-to-Home. -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () { /* swallow */ });
        });
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
