    gap: var(--space-lg);
  }

  .portfolio-grid {
    grid-template-columns: 1fr;
  }

  .services-grid {
    grid-template-columns: 1fr;
  }

  .process-step {
    flex-direction: column;
    gap: var(--space-sm);
  }

  .process-line {
    margin-left: 0;
    width: 40px;
    height: 2px;
    margin: var(--space-sm) 0;
  }

  .footer-grid {
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }
}
</style>

<script>
  function initSite() {
    // @ts-ignore
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
      setTimeout(initSite, 100);
      return;
    }

    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    const loader = document.getElementById('loader');
    const loaderText = document.getElementById('loader-text');
    const loaderBar = document.getElementById('loader-bar');

    // @ts-ignore
    const loaderTl = gsap.timeline({
      onComplete: () => {
        // @ts-ignore
        gsap.to(loader, {
          yPercent: -100,
          duration: 0.8,
          ease: 'power3.inOut',
          onComplete: () => {
            if (loader) loader.style.display = 'none';
            initAnimations();
          }
        });
      }
    });

    loaderTl
      // @ts-ignore
      .to(loaderText, { opacity: 1, duration: 0.6, ease: 'power2.out' })
      // @ts-ignore
      .to(loaderBar, { width: '100%', duration: 1.2, ease: 'power2.inOut' }, '-=0.2');

    // Hero interactive glow
    const heroGlow = document.getElementById('hero-glow');
    const hero = document.getElementById('hero');

    if (hero && heroGlow) {
      hero.addEventListener('mousemove', (e) => {
        const rect = hero.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        // @ts-ignore
        gsap.to(heroGlow, {
          left: x,
          top: y,
          opacity: 1,
          duration: 0.8,
          ease: 'power2.out'
        });
      });

      hero.addEventListener('mouseleave', () => {
        // @ts-ignore
        gsap.to(heroGlow, { opacity: 0, duration: 0.5 });
      });
    }

    // Nav scroll
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav?.classList.add('scrolled');
      } else {
        nav?.classList.remove('scrolled');
      }
    });

    // Mobile menu
    const navToggle = document.getElementById('nav-toggle');
    const navLinks = document.getElementById('nav-links');

    navToggle?.addEventListener('click', () => {
      navLinks?.classList.toggle('active');
      navToggle.classList.toggle('active');
    });

    navLinks?.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('active');
        navToggle?.classList.remove('active');
      });
    });

    // FAQ
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const isActive = item?.classList.contains('active');

        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
        document.querySelectorAll('.faq-question').forEach(q => q.setAttribute('aria-expanded', 'false'));

        if (!isActive && item) {
          item.classList.add('active');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const href = anchor.getAttribute('href');
        if (!href || href === '#') return;
        const target = document.querySelector(href);
        if (target) {
          const offsetY = 80;
          const y = target.getBoundingClientRect().top + window.pageYOffset - offsetY;
          window.scrollTo({ top: y, behavior: 'smooth' });
        }
      });
    });

    function initAnimations() {
      // Hero entrance
      // @ts-ignore
      const heroTl = gsap.timeline();
      heroTl
        .to('.hero-heading', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' }, 0.2)
        .to('.hero-sub', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, 0.5)
        .to('.hero-ctas', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, 0.7)
        .to('.hero-scroll-indicator', { opacity: 1, duration: 0.6 }, 1);

      // Scroll reveals
      // @ts-ignore
      gsap.utils.toArray('.reveal').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, y: 30 },
          {
            opacity: 1, y: 0,
            duration: 0.8,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // @ts-ignore
      gsap.utils.toArray('.reveal-left').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, x: -40 },
          {
            opacity: 1, x: 0,
            duration: 0.8,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // @ts-ignore
      gsap.utils.toArray('.reveal-right').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, x: 40 },
          {
            opacity: 1, x: 0,
            duration: 0.8,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // Staggered service cards
      // @ts-ignore
      gsap.fromTo('.service-card',
        { opacity: 0, y: 40 },
        {
          opacity: 1, y: 0,
          duration: 0.6,
          stagger: 0.15,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: '.services-grid',
            start: 'top 80%'
          }
        }
      );

      // Process steps
      // @ts-ignore
      gsap.fromTo('.process-step',
        { opacity: 0, x: -30 },
        {
          opacity: 1, x: 0,
          duration: 0.6,
          stagger: 0.2,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: '.process-grid',
            start: 'top 80%'
          }
        }
      );

      // Process lines
      // @ts-ignore
      gsap.fromTo('.process-line',
        { scaleY: 0 },
        {
          scaleY: 1,
          duration: 0.4,
          stagger: 0.2,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.process-grid',
            start: 'top 80%'
          }
        }
      );
    }
  }

  initSite();
</script>
