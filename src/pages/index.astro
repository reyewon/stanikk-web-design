<main id="main-content">
<!-- === HERO === -->
<section class="hero" id="hero" aria-labelledby="hero-heading">
  <canvas class="hero-waves" id="hero-waves" aria-hidden="true" role="presentation"></canvas>
  <div class="hero-content container">
    <h1 class="hero-heading" id="hero-heading">
      <span class="hero-word"><span class="hero-word-inner">WEBSITES</span></span>
      <span class="hero-word"><span class="hero-word-inner">THAT</span></span>
      <span class="hero-word accent"><span class="hero-word-inner">WORK</span></span>
      <span class="hero-word"><span class="hero-word-inner">AS</span></span>
      <span class="hero-word"><span class="hero-word-inner">HARD</span></span>
      <span class="hero-word"><span class="hero-word-inner">AS</span></span>
      <span class="hero-word"><span class="hero-word-inner">YOU</span></span>
      <span class="hero-word"><span class="hero-word-inner">DO</span></span>
    </h1>
    <p class="hero-sub">Design-led websites at a fraction of agency prices. 17+ years of graphic design and marketing expertise behind every pixel.</p>
    <div class="hero-ctas">
      <a href="#portfolio" class="btn btn-primary">See My Work</a>
      <a href="https://wa.me/442381112819" class="btn btn-outline" target="_blank" rel="noopener">WhatsApp Me</a>
    </div>
  </div>
  <div class="hero-scroll-indicator" aria-hidden="true">
    <div class="hero-scroll-line"></div>
  </div>
</section>

<div class="page-content" id="page-content">
<!-- === ABOUT === -->
<section class="about section dark-section" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="about-grid">
      <div class="about-image reveal-left">
        <div class="about-image-wrapper" id="about-image-wrapper">
          <picture>
            <source media="(max-width: 768px)" srcset="/images/ryan-stanikk-square.jpg" />
            <img src="/images/ryan-stanikk.jpg" alt="Ryan Stanikk - Web Designer in Southampton, Hampshire, with 17 years of graphic design experience" loading="lazy" />
          </picture>
          <video src="/images/ryan-stanikk.mp4" id="profile-video" muted playsinline preload="metadata" aria-label="Ryan Stanikk introduction video"></video>
        </div>
      </div>
      <div class="about-text reveal-right">
        <span class="about-label">About Me</span>
        <h2 id="about-heading">I build websites the way I shoot photos. With purpose.</h2>
        <p>I am Ryan Stanikk, a graphic designer with over 17 years in design and marketing, now channelling that expertise into building bespoke websites for businesses that want to stand out online.</p>
        <p>As a <a href="https://ryanstanikk.co.uk" target="_blank" rel="noopener">commercial photographer</a>, I have spent years understanding what makes visuals work commercially, not just aesthetically. That same philosophy drives every website I build: it has to look stunning, but more importantly, it has to perform.</p>
        <p>Based in Southampton, available across the UK. If you are local, I will come to you in person. If you are further afield, I am a video call away. Either way, I sit down with you, get to know your business inside out, and craft something that reflects exactly who you are and what you need.</p>
        <div class="about-stats">
          <div class="stat">
            <span class="stat-number">17+</span>
            <span class="stat-label">Years in Design</span>
          </div>
          <div class="stat">
            <span class="stat-number">6</span>
            <span class="stat-label">Live Projects</span>
          </div>
          <div class="stat">
            <span class="stat-number">UK</span>
            <span class="stat-label">Wide Service</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- === PORTFOLIO === -->
<section class="portfolio section terracotta-section" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="container">
    <div class="section-header">
      <h2 class="blur-reveal" id="portfolio-heading">My Work</h2>
      <a href="#contact" class="section-link reveal">Get Yours Built <span aria-hidden="true">&rarr;</span></a>
    </div>
    <p class="portfolio-intro reveal">Every project is designed to help a business grow. Here is a look at some of the websites I have crafted that drive results and make brands shine.</p>

    <!-- 3-column portfolio grid -->
    <div class="portfolio-columns" id="portfolio-columns">
      <div class="portfolio-col" id="project-1">
        <div class="project-browser reveal">
          <div class="browser-chrome" aria-hidden="true">
            <div class="browser-dots"><span></span><span></span><span></span></div>
            <div class="browser-title">Soleto</div>
          </div>
          <div class="browser-viewport">
            <img src="/images/portfolio/soleto.jpg" alt="Soleto Italian Restaurant - bespoke website design with dark theme, gallery and private dining pages" loading="lazy" />
          </div>
        </div>
        <div class="project-info reveal">
          <h3>Soleto</h3>
          <p>Refined Italian bistro with dark mode, gallery, private dining pages, and elegant typography.</p>
          <a href="https://soleto-website.pages.dev" target="_blank" rel="noopener" class="btn btn-outline btn-sm" aria-label="Visit Soleto website">Visit Site <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>

      <div class="portfolio-col" id="project-2">
        <div class="project-browser reveal">
          <div class="browser-chrome" aria-hidden="true">
            <div class="browser-dots"><span></span><span></span><span></span></div>
            <div class="browser-title">Ark Angels</div>
          </div>
          <div class="browser-viewport">
            <img src="/images/portfolio/ark-angels.jpg" alt="Ark Angels community platform - vibrant website design with event listings and bold layout" loading="lazy" />
          </div>
        </div>
        <div class="project-info reveal">
          <h3>Ark Angels</h3>
          <p>Vibrant community platform with bold design, event listings, and engaging content layout.</p>
          <a href="https://ark-angels-cardover.pages.dev" target="_blank" rel="noopener" class="btn btn-outline btn-sm" aria-label="Visit Ark Angels website">Visit Site <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>

      <div class="portfolio-col" id="project-3">
        <div class="project-browser reveal">
          <div class="browser-chrome" aria-hidden="true">
            <div class="browser-dots"><span></span><span></span><span></span></div>
            <div class="browser-title">Padharo</div>
          </div>
          <div class="browser-viewport">
            <img src="/images/portfolio/padharo.jpg" alt="Padharo vegetarian Indian restaurant - award-winning website with reservation system and menus" loading="lazy" />
          </div>
        </div>
        <div class="project-info reveal">
          <h3>Padharo</h3>
          <p>Award-winning vegetarian Indian restaurant with reservation system, menus, and gallery.</p>
          <a href="https://www.padharo.co.uk" target="_blank" rel="noopener" class="btn btn-outline btn-sm" aria-label="Visit Padharo website">Visit Site <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- === SERVICES === -->
<section class="services section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="section-header">
      <h2 class="blur-reveal" id="services-heading">What I Do</h2>
    </div>

    <div class="services-grid">
      <div class="service-card reveal">
        <div class="service-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <span class="service-badge">Design</span>
        <h3>Web Design</h3>
        <p>Bespoke websites built around your business, not around a template. Most developers build functional sites. I build beautiful ones, with the eye of a graphic designer and at a price that undercuts agencies and freelance developers alike.</p>
        <ul class="service-list">
          <li>Custom design</li>
          <li>Mobile-first</li>
          <li>Built to convert</li>
          <li>SEO foundations</li>
        </ul>
        <a href="#contact" class="btn-card" aria-label="Get started with Web Design">Get Started</a>
      </div>

      <div class="service-card reveal">
        <div class="service-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="12" y1="2" x2="12" y2="22"/></svg>
        </div>
        <span class="service-badge">Development</span>
        <h3>Web Apps</h3>
        <p>More than just websites. I build functional web applications with the features your business needs, from content management to bespoke tools.</p>
        <ul class="service-list">
          <li>Custom web apps</li>
          <li>CMS integration</li>
          <li>Interactive features</li>
          <li>Performance-first</li>
        </ul>
        <a href="#contact" class="btn-card" aria-label="Get started with Web Apps">Get Started</a>
      </div>

      <div class="service-card reveal">
        <div class="service-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <span class="service-badge">Infrastructure</span>
        <h3>Hosting & Domains</h3>
        <p>I handle the technical side so you do not have to. Domain registration, hosting setup, SSL certificates, and ongoing maintenance all taken care of.</p>
        <ul class="service-list">
          <li>Domain registration</li>
          <li>Fast, secure hosting</li>
          <li>SSL certificates</li>
          <li>Ongoing support</li>
        </ul>
        <a href="#contact" class="btn-card" aria-label="Get started with Hosting and Domains">Get Started</a>
      </div>

      <div class="service-card reveal">
        <div class="service-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </div>
        <span class="service-badge">Content</span>
        <h3>Content Management</h3>
        <p>Need something changed on your site? Send it over and I will handle it. If you prefer to manage content yourself, I can build a CMS into your site too.</p>
        <ul class="service-list">
          <li>Quick turnaround updates</li>
          <li>Optional CMS</li>
          <li>No lock-in</li>
          <li>Full control</li>
        </ul>
        <a href="#contact" class="btn-card" aria-label="Get started with Content Management">Get Started</a>
      </div>
    </div>
  </div>
</section>

<!-- === PRICING === -->
<section class="pricing section" id="pricing" aria-labelledby="pricing-heading">
  <div class="container">
    <div class="section-header">
      <h2 class="blur-reveal" id="pricing-heading">Investment</h2>
    </div>

    <div class="pricing-toggle-wrap reveal">
      <span class="pricing-toggle-label" id="toggle-label-monthly">Monthly</span>
      <button class="pricing-toggle" id="pricing-toggle" role="switch" aria-checked="false" aria-label="Switch between monthly and pay upfront pricing">
        <span class="pricing-toggle-thumb"></span>
      </button>
      <span class="pricing-toggle-label" id="toggle-label-oneoff">Pay Upfront</span>
    </div>

    <div class="pricing-grid">
      <div class="pricing-card reveal" data-tier="starter">
        <div class="pricing-card-inner">
          <span class="pricing-tier">Starter</span>
          <p class="pricing-desc">A single-page site that makes you look as good online as you are in person.</p>
          <div class="pricing-amount">
            <span class="pricing-currency">&pound;</span>
            <span class="pricing-value" data-monthly="49" data-upfront="199">49</span>
            <span class="pricing-period">/mo</span>
          </div>
          <span class="pricing-commitment">12-month commitment</span>
          <span class="pricing-renewal">Then &pound;29/mo</span>
          <ul class="pricing-features">
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Custom single-page design</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Mobile-first &amp; responsive</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> SEO foundations</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Hosting &amp; SSL included</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Ongoing support</li>
          </ul>
          <a href="#contact" class="btn-card">Get Started</a>
        </div>
      </div>

      <div class="pricing-card pricing-card--featured reveal" data-tier="business">
        <div class="pricing-badge">Most Popular</div>
        <div class="pricing-card-inner">
          <span class="pricing-tier">Business</span>
          <p class="pricing-desc">Multi-page site with everything you need to grow your business online.</p>
          <div class="pricing-amount">
            <span class="pricing-currency">&pound;</span>
            <span class="pricing-value" data-monthly="79" data-upfront="299">79</span>
            <span class="pricing-period">/mo</span>
          </div>
          <span class="pricing-commitment">12-month commitment</span>
          <span class="pricing-renewal">Then &pound;49/mo</span>
          <ul class="pricing-features">
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Up to 5 custom pages</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Contact forms</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Google Business integration</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Everything in Starter</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Priority support</li>
          </ul>
          <a href="#contact" class="btn-card">Get Started</a>
        </div>
      </div>

      <div class="pricing-card reveal" data-tier="professional">
        <div class="pricing-card-inner">
          <span class="pricing-tier">Professional</span>
          <p class="pricing-desc">Larger sites with CMS, advanced integrations, and room to grow.</p>
          <div class="pricing-amount">
            <span class="pricing-currency">&pound;</span>
            <span class="pricing-value" data-monthly="149" data-upfront="499">149</span>
            <span class="pricing-period">/mo</span>
          </div>
          <span class="pricing-commitment">12-month commitment</span>
          <span class="pricing-renewal">Then &pound;99/mo</span>
          <ul class="pricing-features">
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Up to 15 custom pages</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> CMS integration</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Advanced integrations</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Everything in Business</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Dedicated support</li>
          </ul>
          <a href="#contact" class="btn-card">Get Started</a>
        </div>
      </div>

    </div>

    <div class="pricing-enterprise reveal">
      <p>Got a larger project in mind? Need e-commerce, custom features, or something more ambitious? <a href="#contact">Get in touch for a custom quote</a>.</p>
    </div>

    <p class="pricing-note reveal">All plans include hosting, SSL, domain setup, and ongoing support. Monthly pricing includes your build cost spread over 12 months. Pay upfront to start at the lower retainer rate immediately. Day-to-day updates like text changes, image swaps, and menu updates are always included. Larger changes may need to be quoted separately depending on their complexity.</p>
  </div>
</section>

<!-- === PROCESS === -->
<section class="process section dark-section" id="process" aria-labelledby="process-heading">
  <div class="container">
    <div class="section-header">
      <h2 class="blur-reveal" id="process-heading">How I Work</h2>
    </div>

    <div class="process-layout">
      <div class="process-image reveal-left">
        <img src="/images/room2-laptop.jpg" alt="Business owner working at their laptop in a café - the kind of clients I work with" loading="lazy" />
      </div>
      <div class="process-grid" role="list" aria-label="My 5-step process">
        <div class="process-step reveal" role="listitem">
          <div class="process-number" aria-hidden="true">01</div>
          <div class="process-content">
            <h3>Discovery</h3>
            <p>A proper conversation about your business, your brand, and your goals. Face to face if you are local, video call if not.</p>
          </div>
        </div>
        <div class="process-line" aria-hidden="true"></div>

        <div class="process-step reveal" role="listitem">
          <div class="process-number" aria-hidden="true">02</div>
          <div class="process-content">
            <h3>Design</h3>
            <p>Layouts crafted with the mind of a graphic designer and the eye of a photographer. Every element is intentional.</p>
          </div>
        </div>
        <div class="process-line" aria-hidden="true"></div>

        <div class="process-step reveal" role="listitem">
          <div class="process-number" aria-hidden="true">03</div>
          <div class="process-content">
            <h3>Build</h3>
            <p>Clean, fast, accessible code built for performance and SEO from the ground up.</p>
          </div>
        </div>
        <div class="process-line" aria-hidden="true"></div>

        <div class="process-step reveal" role="listitem">
          <div class="process-number" aria-hidden="true">04</div>
          <div class="process-content">
            <h3>Launch</h3>
            <p>Domain, hosting, SSL, testing. I handle every detail of deployment.</p>
          </div>
        </div>
        <div class="process-line" aria-hidden="true"></div>

        <div class="process-step reveal" role="listitem">
          <div class="process-number" aria-hidden="true">05</div>
          <div class="process-content">
            <h3>Support</h3>
            <p>I do not disappear after launch. Ongoing updates and maintenance included.</p>
