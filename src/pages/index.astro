</style>

<script>
  /* ================================================================
     SIDE RAIL — runs independently of GSAP/Lenis so it works even if
     those libs are slow to load. Slides in on first 40 px scroll and
     persists; expands on hover (desktop) / tap (mobile); current
     section tracked via IntersectionObserver.
     ================================================================ */
  function initRail() {
    const rail = document.getElementById('rail');
    const burger = document.getElementById('rail-burger');
    const logo = document.getElementById('rail-logo');
    const backdrop = document.getElementById('rail-backdrop');
    if (!rail || !burger || !logo || !backdrop) return;

    const isMobile = () => window.matchMedia('(max-width: 820px)').matches;
    let collapseTimer: number | undefined;
    let scrollLocked = false;

    /* --- 1. Slide rail in past the 40 px scroll threshold; pull it
       back out (and bring the centered hero-mark back) when the user
       returns to the very top. The threshold is a band, not a hard
       line, so we don't snap on/off with sub-pixel scroll jitter. */
    // Hysteresis band: reveal once you've committed to scrolling, retract
    // well before you reach the very top so the centred hero-mark has
    // room to come back in cleanly.
    const SHOW = 100;
    const HIDE = 60;
    function checkScroll() {
      const y = window.scrollY;
      const cls = document.body.classList;
      if (y > SHOW && !cls.contains('rail-in')) {
        cls.add('rail-in');
      } else if (y < HIDE && cls.contains('rail-in')) {
        cls.remove('rail-in');
        // Also collapse and un-lock if the rail was open mid-page on mobile
        rail.classList.remove('expanded');
        backdrop.classList.remove('visible');
        burger.classList.remove('active');
        burger.setAttribute('aria-expanded', 'false');
        if (scrollLocked) {
          document.body.style.overflow = '';
          scrollLocked = false;
        }
      }
    }
    window.addEventListener('scroll', checkScroll, { passive: true });
    // Catch initial scroll position (deep link to anchor, page reload mid-scroll, etc.)
    checkScroll();

    /* --- 2. Desktop: hover with 120 ms grace timeout --- */
    rail.addEventListener('mouseenter', () => {
      if (isMobile()) return;
      if (collapseTimer) { clearTimeout(collapseTimer); collapseTimer = undefined; }
      rail.classList.add('expanded');
    });
    rail.addEventListener('mouseleave', () => {
      if (isMobile()) return;
      collapseTimer = window.setTimeout(() => {
        rail.classList.remove('expanded');
      }, 120);
    });

    /* --- 3. Mobile: tap to expand, backdrop or Escape to close --- */
    function expandMobile() {
      rail.classList.add('expanded');
      backdrop.classList.add('visible');
      burger.classList.add('active');
      burger.setAttribute('aria-expanded', 'true');
      if (!scrollLocked) {
        document.body.style.overflow = 'hidden';
        scrollLocked = true;
      }
    }
    function collapseMobile() {
      rail.classList.remove('expanded');
      backdrop.classList.remove('visible');
      burger.classList.remove('active');
      burger.setAttribute('aria-expanded', 'false');
      if (scrollLocked) {
        document.body.style.overflow = '';
        scrollLocked = false;
      }
    }

    burger.addEventListener('click', () => {
      if (!isMobile()) return;
      if (rail.classList.contains('expanded')) collapseMobile();
      else expandMobile();
    });

    logo.addEventListener('click', (e) => {
      // On mobile, first tap on logo opens drawer instead of navigating
      if (isMobile() && !rail.classList.contains('expanded')) {
        e.preventDefault();
        expandMobile();
      }
    });

    backdrop.addEventListener('click', collapseMobile);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMobile() && rail.classList.contains('expanded')) {
        collapseMobile();
      }
    });

    // Tapping any link in the drawer auto-closes (mobile only)
    rail.querySelectorAll('.rail-item, .rail-cta').forEach((link) => {
      link.addEventListener('click', () => {
        if (isMobile()) collapseMobile();
      });
    });

    /* --- 4. Current-section indicator via IntersectionObserver ---
       Trigger band is the middle of the viewport (40% from top, 55%
       from bottom) so the bar lights up the section the user is
       actually reading, not whichever sliver pokes into view. */
    const items = Array.from(rail.querySelectorAll('.rail-item')) as HTMLElement[];
    const sections = items
      .map((item) => {
        const id = item.getAttribute('data-section');
        return id ? document.getElementById(id) : null;
      })
      .filter((s): s is HTMLElement => s !== null);

    if (sections.length) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            items.forEach((item) => {
              item.classList.toggle('current', item.getAttribute('data-section') === id);
            });
          }
        });
      }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
      sections.forEach((s) => observer.observe(s));
    }

    /* --- 5. Re-check viewport on resize so mobile↔desktop switching
       doesn't leave the drawer in a stuck state --- */
    let lastIsMobile = isMobile();
    window.addEventListener('resize', () => {
      const nowMobile = isMobile();
      if (lastIsMobile !== nowMobile) {
        // Crossing the breakpoint: collapse and unlock everything
        rail.classList.remove('expanded');
        backdrop.classList.remove('visible');
        burger.classList.remove('active');
        burger.setAttribute('aria-expanded', 'false');
        if (scrollLocked) {
          document.body.style.overflow = '';
          scrollLocked = false;
        }
        lastIsMobile = nowMobile;
      }
    });
  }

  // Run the rail as soon as DOM is ready — no GSAP dependency
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRail);
  } else {
    initRail();
  }

  function initSite() {
    // @ts-ignore
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined' || typeof Lenis === 'undefined') {
      setTimeout(initSite, 100);
      return;
    }

    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    // @ts-ignore
    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    // @ts-ignore
    window.__lenis = lenis;
    // Sync Lenis scroll position with GSAP ScrollTrigger
    // @ts-ignore
    lenis.on('scroll', ScrollTrigger.update);
    // Drive Lenis from its own RAF loop
    function lenisRaf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(lenisRaf);
    }
    requestAnimationFrame(lenisRaf);

    // Character split helper for blur-reveal effect
    function splitChars(el: Element) {
      const text = el.textContent || '';
      el.textContent = '';
      const chars: HTMLSpanElement[] = [];
      for (const char of text) {
        const span = document.createElement('span');
        if (char === ' ') {
          span.innerHTML = ' ';
        } else {
          span.textContent = char;
        }
        span.style.display = 'inline';
        span.style.opacity = '0';
        span.style.filter = 'blur(12px)';
        el.appendChild(span);
        chars.push(span);
      }
      return chars;
    }

    const loader = document.getElementById('loader');
    const loaderText = document.getElementById('loader-text');
    const loaderBar = document.getElementById('loader-bar');

    // @ts-ignore
    const loaderTl = gsap.timeline({
      onComplete: () => {
        // @ts-ignore
        gsap.to(loader, {
          yPercent: -100,
          duration: 0.8,
          ease: 'power3.inOut',
          onComplete: () => {
            if (loader) { loader.style.display = 'none'; loader.setAttribute('aria-hidden', 'true'); }
            initAnimations();
          }
        });
      }
    });

    loaderTl
      // @ts-ignore
      .to(loaderText, { opacity: 1, duration: 0.6, ease: 'power2.out' })
      // @ts-ignore
      .to(loaderBar, { width: '100%', duration: 1.2, ease: 'power2.inOut' }, '-=0.2');

    // Hero word reveal is handled in initAnimations

    // Mesh gradient shader is initialized in the bundled <script> tag above

    // (Old top-nav scroll/show/hide and mobile-menu logic removed —
    //  the side rail now owns navigation. The hero-mark fades out via
    //  a pure CSS transition triggered by body.rail-in.)

    // Profile video hover (desktop) / scroll auto-play (mobile)
    const profileWrapper = document.getElementById('about-image-wrapper');
    const profileVideo = document.getElementById('profile-video');
    if (profileWrapper && profileVideo) {
      const isMobile = window.matchMedia('(max-width: 768px)').matches;
      let videoHasPlayed = false;

      function onVideoEnd() {
        profileWrapper.classList.remove('video-playing');
        profileVideo.currentTime = 0;
        videoHasPlayed = true;
      }

      profileVideo.addEventListener('ended', onVideoEnd);

      if (!isMobile) {
        // Desktop: play on hover, switch back when done, allow re-hover
        profileWrapper.addEventListener('mouseenter', () => {
          profileVideo.currentTime = 0;
          profileVideo.play();
          profileWrapper.classList.add('video-playing');
        });

        profileWrapper.addEventListener('mouseleave', () => {
          // If video is still playing when mouse leaves, let it finish
          // but if they leave we should stop and reset
          profileVideo.pause();
          profileWrapper.classList.remove('video-playing');
          profileVideo.currentTime = 0;
        });
      } else {
        // Mobile: auto-play once when 1/3 up the viewport
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !videoHasPlayed) {
              videoHasPlayed = true;
              profileVideo.currentTime = 0;
              profileVideo.play();
              profileWrapper.classList.add('video-playing');
              observer.disconnect();
            }
          });
        }, {
          threshold: 0.5,
          rootMargin: '0px 0px -33% 0px'
        });
        observer.observe(profileWrapper);
      }
    }

    // Portfolio: composite preview = live iframe (hero, correct viewport) + screenshot (rest)
    // Embedded site renders at 1024×1366 (iPad portrait desktop) so 100vh is correct.
    // The screenshot underneath provides content beyond the hero — both pan together on hover.
    const viewports = document.querySelectorAll('.browser-viewport');
    const isMobilePort = window.matchMedia('(max-width: 768px)').matches;
    const SITE_WIDTH = 1024;
    const HERO_HEIGHT = 1366; // iframe height = iPad Pro portrait
    const PAN_DURATION_MS = 7000;

    function calcScale(viewport: Element) {
      return (viewport as HTMLElement).clientWidth / SITE_WIDTH;
    }

    viewports.forEach(viewport => {
      const vp = viewport as HTMLElement;
      const siteUrl = vp.dataset.site;
      const stack = vp.querySelector('.browser-stack') as HTMLElement | null;
      const poster = vp.querySelector('.browser-poster') as HTMLImageElement | null;
      if (!siteUrl || !stack || !poster) return;

      let iframe: HTMLIFrameElement | null = null;
      let scale = calcScale(vp);
      let animId: number | null = null;
      let currentTop = 0;
      let mobileCompleted = false;

      function applyStackTransform(top: number) {
        stack!.style.transform = `translateY(${top}px) scale(${scale})`;
      }

      function maxPan(): number {
        // Stack rendered height = poster's natural height × scale
        const stackRenderedHeight = poster!.naturalHeight * scale;
        return Math.max(0, stackRenderedHeight - vp.offsetHeight);
      }

      function mountIframe() {
        if (iframe) return;
        iframe = document.createElement('iframe');
        iframe.src = siteUrl!;
        iframe.loading = 'lazy';
        iframe.title = poster!.alt || 'Site preview';
        iframe.tabIndex = -1;
        iframe.setAttribute('aria-hidden', 'true');
        iframe.setAttribute('sandbox', 'allow-scripts allow-same-origin');
        // iframe sits absolute on top of the screenshot, only covering the hero portion.
        Object.assign(iframe.style, {
          position: 'absolute',
          top: '0',
          left: '0',
          width: SITE_WIDTH + 'px',
          height: HERO_HEIGHT + 'px',
          border: '0',
          pointerEvents: 'none',
          opacity: '0',
          transition: 'opacity 0.5s ease-out',
          zIndex: '2',
        });
        iframe.addEventListener('load', () => {
          if (!iframe) return;
          iframe.style.opacity = '1';
        });
        stack!.appendChild(iframe);
      }

      // Initial scale (do this before iframe loads so the screenshot is positioned correctly)
      applyStackTransform(0);

      function startPan() {
        if (animId) return;
        if (isMobilePort && mobileCompleted) return;
        const target = -maxPan();
        if (target === 0) return;
        const start = performance.now();
        const from = currentTop;
        const distance = target - from;

        function step(now: number) {
          const elapsed = now - start;
          const t = Math.min(elapsed / PAN_DURATION_MS, 1);
          const eased = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
          currentTop = from + distance * eased;
          applyStackTransform(currentTop);
          if (t < 1) {
            animId = requestAnimationFrame(step);
          } else {
            animId = null;
            if (isMobilePort) {
              mobileCompleted = true;
              setTimeout(() => {
                stack!.style.transition = 'transform 0.9s ease-out';
                currentTop = 0;
                applyStackTransform(currentTop);
                setTimeout(() => {
                  stack!.style.transition = '';
                }, 1000);
              }, 700);
            }
          }
        }
        stack!.style.transition = '';
        animId = requestAnimationFrame(step);
      }

      function resetPan() {
        if (animId) {
          cancelAnimationFrame(animId);
          animId = null;
        }
        stack!.style.transition = 'transform 0.6s ease-out';
        currentTop = 0;
        applyStackTransform(currentTop);
      }

      window.addEventListener('resize', () => {
        scale = calcScale(vp);
        applyStackTransform(currentTop);
      });

      // Mobile: skip iframe mounting entirely — three live cross-origin iframes
      // running simultaneously cause significant performance issues (jank, repaint
      // glitches) on phones. The static screenshot still pans on hover/in-view, so
      // mobile users get the same effect minus the live hero video.
      if (!isMobilePort) {
        const mountObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              if (poster && poster.complete && poster.naturalWidth > 0) {
                mountIframe();
              } else if (poster) {
                poster.addEventListener('load', () => mountIframe(), { once: true });
              } else {
                mountIframe();
              }
              mountObserver.unobserve(vp);
            }
          });
        }, { rootMargin: '200px' });
        mountObserver.observe(vp);
      }

      if (!isMobilePort) {
        const card = vp.closest('.project-browser');
        if (card) {
          card.addEventListener('mouseenter', startPan);
          card.addEventListener('mouseleave', resetPan);
        }
      }

      (vp as any)._startPan = startPan;
      (vp as any)._resetPan = resetPan;
    });

    // Mobile: one card auto-pans at a time when in view
    if (isMobilePort) {
      let activeViewport: any = null;
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const target = entry.target as any;
          if (entry.isIntersecting) {
            if (activeViewport && activeViewport !== target) {
              activeViewport._resetPan();
            }
            activeViewport = target;
            target._startPan();
          } else {
            target._resetPan();
            if (activeViewport === target) activeViewport = null;
          }
        });
      }, { threshold: 0.4 });
      viewports.forEach(vp => observer.observe(vp));
    }

    // FAQ
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const isActive = item?.classList.contains('active');

        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
        document.querySelectorAll('.faq-question').forEach(q => q.setAttribute('aria-expanded', 'false'));

        if (!isActive && item) {
          item.classList.add('active');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Service card expand/collapse on mobile
    if (window.innerWidth <= 768) {
      document.querySelectorAll('.service-card').forEach(card => {
        // Add "Read more" link
        const moreLink = document.createElement('span');
        moreLink.className = 'service-more';
        moreLink.textContent = 'Read more';
        const desc = card.querySelector('p');
        if (desc) desc.after(moreLink);

        // Toggle on "Read more" or card heading click
        const toggle = () => card.classList.toggle('service-expanded');
        moreLink.addEventListener('click', toggle);
        const h3 = card.querySelector('h3');
        if (h3) h3.addEventListener('click', toggle);
      });

      // Scroll pricing to Business (middle) card
      const pricingGrid = document.querySelector('.pricing-grid');
      const businessCard = document.querySelector('[data-tier="business"]');
      if (pricingGrid && businessCard) {
        requestAnimationFrame(() => {
          const gridLeft = pricingGrid.getBoundingClientRect().left;
          const cardLeft = businessCard.getBoundingClientRect().left;
          const cardWidth = businessCard.getBoundingClientRect().width;
          const gridWidth = pricingGrid.getBoundingClientRect().width;
          const scrollTo = cardLeft - gridLeft - (gridWidth - cardWidth) / 2 + pricingGrid.scrollLeft;
          pricingGrid.scrollTo({ left: scrollTo, behavior: 'instant' });
        });
      }
    }

    // Pricing toggle
    const pricingToggle = document.getElementById('pricing-toggle');
    const labelMonthly = document.getElementById('toggle-label-monthly');
    const labelOneoff = document.getElementById('toggle-label-oneoff');
    const priceValues = document.querySelectorAll('.pricing-value');
    const pricePeriods = document.querySelectorAll('.pricing-period');
    const priceCommitments = document.querySelectorAll('.pricing-commitment');
    const priceRenewals = document.querySelectorAll('.pricing-renewal');

    if (labelMonthly) labelMonthly.classList.add('active');

    pricingToggle?.addEventListener('click', () => {
      const isUpfront = pricingToggle.getAttribute('aria-checked') === 'true';
      pricingToggle.setAttribute('aria-checked', String(!isUpfront));

      if (!isUpfront) {
        // Switching to pay upfront
        labelOneoff?.classList.add('active');
        labelMonthly?.classList.remove('active');
        priceValues.forEach(el => {
          el.style.opacity = '0';
          setTimeout(() => {
            el.textContent = el.dataset.upfront;
            el.style.opacity = '1';
          }, 150);
        });
        pricePeriods.forEach(el => el.style.display = 'none');
        priceCommitments.forEach(el => el.textContent = 'One-off build fee');
        const retainerRates = ['29', '49', '99'];
        priceRenewals.forEach((el, i) => el.textContent = 'Then \u00A3' + retainerRates[i] + '/mo');
      } else {
        // Switching to monthly
        labelMonthly?.classList.add('active');
        labelOneoff?.classList.remove('active');
        priceValues.forEach(el => {
          el.style.opacity = '0';
          setTimeout(() => {
            el.textContent = el.dataset.monthly;
            el.style.opacity = '1';
          }, 150);
        });
        pricePeriods.forEach(el => el.style.display = '');
        priceCommitments.forEach(el => el.textContent = '12-month commitment');
        const renewalRates = ['29', '49', '99'];
        priceRenewals.forEach((el, i) => el.textContent = 'Then \u00A3' + renewalRates[i] + '/mo');
      }
    });

    // Audit form
    const auditForm = document.getElementById('audit-form');
    const auditSuccess = document.getElementById('audit-success');
    auditForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      const url = document.getElementById('audit-url')?.value;
      if (!url) return;

      // Open WhatsApp with the URL pre-filled
      const message = encodeURIComponent('Hi Ryan, I would like a free website review for: ' + url);
      window.open('https://wa.me/442381112819?text=' + message, '_blank');

      // Show success state
      auditForm.hidden = true;
      if (auditSuccess) auditSuccess.hidden = false;
    });

    // Smooth scroll via Lenis
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const href = anchor.getAttribute('href');
        if (!href || href === '#') return;
        const target = document.querySelector(href);
        if (target) {
          // @ts-ignore
          window.__lenis.scrollTo(target, { offset: -80 });
        }
      });
    });

    function initAnimations() {
      // Hero card-over: pin hero, page content scrolls over it
      // @ts-ignore
      ScrollTrigger.create({
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        pin: true,
        pinSpacing: false
      });

      // Hero entrance - character blur reveal
      // @ts-ignore
      const heroTl = gsap.timeline();

      // Split each word into characters and collect all char spans
      const wordInners = document.querySelectorAll('.hero-word-inner');
      const allChars: HTMLSpanElement[] = [];
      wordInners.forEach(word => {
        // Reset the slide-up transform so word is in position
        (word as HTMLElement).style.transform = 'translateY(0)';
        const chars = splitChars(word);
        allChars.push(...chars);
      });

      // @ts-ignore
      heroTl.to(allChars, {
        opacity: 1,
        filter: 'blur(0px)',
        duration: 0.6,
        ease: 'power4.out',
        stagger: 0.025,
      }, 0);

      // Subtitle and CTAs fade in after character reveal
      const charRevealDuration = 0.6 + (allChars.length * 0.025);
      heroTl
        // @ts-ignore
        .to('.hero-sub', { opacity: 1, y: 0, duration: 0.8, ease: 'back.out(1.4)' }, charRevealDuration * 0.6)
        // @ts-ignore
        .to('.hero-ctas', { opacity: 1, y: 0, duration: 0.8, ease: 'back.out(1.4)' }, charRevealDuration * 0.7)
        // @ts-ignore
        .to('.hero-scroll-indicator', { opacity: 1, duration: 0.6 }, charRevealDuration * 0.85);

      // Section heading blur-reveal on scroll
      document.querySelectorAll('.blur-reveal').forEach(heading => {
        const chars = splitChars(heading);
        // @ts-ignore
        gsap.to(chars, {
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.5,
          ease: 'power3.out',
          stagger: 0.02,
          scrollTrigger: {
            trigger: heading,
            start: 'top 85%',
            toggleActions: 'play none none none'
          }
        });
      });

      // Scroll reveals (scale + spring easing)
      // @ts-ignore
      gsap.utils.toArray('.reveal').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, y: 30, scale: 0.97 },
          {
            opacity: 1, y: 0, scale: 1,
            duration: 0.8,
            ease: 'back.out(1.4)',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // @ts-ignore
      gsap.utils.toArray('.reveal-left').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, x: -40, scale: 0.97 },
          {
            opacity: 1, x: 0, scale: 1,
            duration: 0.8,
            ease: 'back.out(1.4)',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // @ts-ignore
      gsap.utils.toArray('.reveal-right').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, x: 40, scale: 0.97 },
          {
            opacity: 1, x: 0, scale: 1,
            duration: 0.8,
            ease: 'back.out(1.4)',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // Staggered service cards
      // @ts-ignore
      gsap.fromTo('.service-card',
        { autoAlpha: 0, y: 40, scale: 0.97 },
        {
          autoAlpha: 1, y: 0, scale: 1,
          duration: 0.6,
          stagger: 0.15,
          ease: 'back.out(1.4)',
          scrollTrigger: {
            trigger: '.services-grid',
            start: 'top 80%'
          },
          onComplete: function() {
            document.querySelectorAll('.service-card').forEach(function(el) { el.classList.add('gsap-revealed'); });
          }
        }
      );

      // Pricing cards
      // @ts-ignore
      gsap.fromTo('.pricing-card',
        { autoAlpha: 0, y: 40, scale: 0.97 },
        {
          autoAlpha: 1, y: 0, scale: 1,
          duration: 0.6,
          stagger: 0.15,
          ease: 'back.out(1.4)',
          scrollTrigger: {
            trigger: '.pricing-grid',
            start: 'top 80%'
          },
          onComplete: function() {
            document.querySelectorAll('.pricing-card').forEach(function(el) { el.classList.add('gsap-revealed'); });
          }
        }
      );

      // Process steps
      // @ts-ignore
      gsap.fromTo('.process-step',
        { autoAlpha: 0, x: -30, scale: 0.97 },
        {
          autoAlpha: 1, x: 0, scale: 1,
          duration: 0.6,
          stagger: 0.2,
          ease: 'back.out(1.4)',
          scrollTrigger: {
            trigger: '.process-grid',
            start: 'top 80%'
          }
        }
      );

      // Process lines
      // @ts-ignore
      gsap.fromTo('.process-line',
        { autoAlpha: 0, scaleY: 0 },
        {
          autoAlpha: 1, scaleY: 1,
          duration: 0.4,
          stagger: 0.2,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.process-grid',
            start: 'top 80%'
          }
        }
      );

      // Parallax on hero shader
      const shaderEl = document.getElementById('hero-shader');
      if (shaderEl) {
        // @ts-ignore
        gsap.to(shaderEl, {
          yPercent: 30,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom top',
            scrub: true
          }
        });
      }
    }
  }

  initSite();
</script>
