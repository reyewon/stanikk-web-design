---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Web Design Southampton | Bespoke Websites | Kombu" description="Bespoke web design in Southampton, serving the UK. Design-led websites without the agency headaches. Personal service with almost two decades of design expertise.">

<a href="#main-content" class="skip-link">Skip to main content</a>

<!-- === LOADER === -->
<div class="loader" id="loader" role="status" aria-label="Loading Kombu">
  <img class="loader-mark" src="/images/loader-mark.png" alt="" aria-hidden="true" />
  <div class="loader-text" id="loader-text">
    <span class="loader-name">Kombu</span>
    <span class="loader-sub">Web Design</span>
  </div>
  <div class="loader-bar" id="loader-bar"></div>
</div>

<!-- (Old top nav removed — the side rail handles all navigation now.) -->

<!-- === HERO-MARK — centered Kombu lockup floating above the hero text.
     Sits roughly halfway between the top of the page and the hero heading.
     Fades out as soon as the user starts scrolling and the side rail
     takes over (body.rail-in). === -->
<a href="#hero" class="hero-mark" id="hero-mark" aria-label="Kombu Web Design — top">
  <span class="hero-mark-name">Kombu</span>
  <span class="hero-mark-sub">Web Design</span>
</a>

<!-- === SIDE RAIL (editorial vertical nav) === -->
<aside class="rail" id="rail" aria-label="Site navigation">
  <button class="rail-burger" id="rail-burger" type="button" aria-label="Open navigation" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <a href="#hero" class="rail-logo" id="rail-logo" aria-label="Kombu Web Design — back to top">
    <img class="rail-mark" src="/images/loader-mark.png" alt="" aria-hidden="true" />
    <span class="rail-wordmark" aria-hidden="true">
      <span class="rail-wordmark-name">Kombu</span>
      <span class="rail-wordmark-sub">Web Design</span>
    </span>
  </a>

  <nav class="rail-nav" aria-label="Page sections">
    <a href="#about" class="rail-item" data-section="about">
      <span class="rail-item-bar" aria-hidden="true"></span>
      <span class="rail-item-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" focusable="false"><circle cx="12" cy="8.5" r="3.6"/><path d="M5 20.5c.7-3.4 3.5-5.4 7-5.4s6.3 2 7 5.4"/></svg>
      </span>
      <span class="rail-item-name">About</span>
    </a>
    <a href="#portfolio" class="rail-item" data-section="portfolio">
      <span class="rail-item-bar" aria-hidden="true"></span>
      <span class="rail-item-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" focusable="false"><rect x="3.5" y="3.5" width="7.5" height="7.5" rx="1.2"/><rect x="13" y="3.5" width="7.5" height="7.5" rx="1.2"/><rect x="3.5" y="13" width="7.5" height="7.5" rx="1.2"/><rect x="13" y="13" width="7.5" height="7.5" rx="1.2"/></svg>
      </span>
      <span class="rail-item-name">Portfolio</span>
    </a>
    <a href="#services" class="rail-item" data-section="services">
      <span class="rail-item-bar" aria-hidden="true"></span>
      <span class="rail-item-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" focusable="false"><path d="M12 3.5l8.5 4.2-8.5 4.2-8.5-4.2L12 3.5z"/><path d="M3.5 12l8.5 4.2 8.5-4.2"/><path d="M3.5 16.3l8.5 4.2 8.5-4.2"/></svg>
      </span>
      <span class="rail-item-name">Services</span>
    </a>
    <a href="#pricing" class="rail-item" data-section="pricing">
      <span class="rail-item-bar" aria-hidden="true"></span>
      <span class="rail-item-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" focusable="false"><path d="M20.4 12.6 12.6 20.4a1.4 1.4 0 0 1-2 0L3.5 13.3v-9.8h9.8l7.1 7.1a1.4 1.4 0 0 1 0 2z"/><circle cx="8.2" cy="8.2" r="1.3"/></svg>
      </span>
      <span class="rail-item-name">Pricing</span>
    </a>
    <a href="#process" class="rail-item" data-section="process">
      <span class="rail-item-bar" aria-hidden="true"></span>
      <span class="rail-item-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" focusable="false"><circle cx="5.6" cy="6.5" r="1.3"/><circle cx="5.6" cy="12" r="1.3"/><circle cx="5.6" cy="17.5" r="1.3"/><path d="M10 6.5h10.5M10 12h10.5M10 17.5h10.5"/></svg>
      </span>
      <span class="rail-item-name">Process</span>
    </a>
    <a href="#faq" class="rail-item" data-section="faq">
      <span class="rail-item-bar" aria-hidden="true"></span>
      <span class="rail-item-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" focusable="false"><circle cx="12" cy="12" r="8.5"/><path d="M9.5 9.4a2.6 2.6 0 0 1 5 .9c0 1.7-2.5 2-2.5 3.7"/><path d="M12 17.2v.05"/></svg>
      </span>
      <span class="rail-item-name">FAQ</span>
    </a>
    <a href="#contact" class="rail-item" data-section="contact">
      <span class="rail-item-bar" aria-hidden="true"></span>
      <span class="rail-item-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" focusable="false"><path d="M3.5 7.2a1.5 1.5 0 0 1 1.5-1.5h14a1.5 1.5 0 0 1 1.5 1.5v9.6a1.5 1.5 0 0 1-1.5 1.5h-14a1.5 1.5 0 0 1-1.5-1.5z"/><path d="m3.7 7.6 7.5 5.4a1.4 1.4 0 0 0 1.6 0l7.5-5.4"/></svg>
      </span>
      <span class="rail-item-name">Contact</span>
    </a>
  </nav>

  <a href="#contact" class="rail-cta" id="rail-cta">
    <span class="rail-cta-text">Start a project</span>
    <span class="rail-cta-arrow" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </span>
  </a>
</aside>

<div class="rail-backdrop" id="rail-backdrop" aria-hidden="true"></div>

<main id="main-content">
<!-- === HERO === -->
<section class="hero" id="hero" aria-labelledby="hero-heading">
  <div class="hero-shader" id="hero-shader" aria-hidden="true"></div>
  <div class="hero-content container">
    <h1 class="hero-heading" id="hero-heading">
      <span class="hero-word"><span class="hero-word-inner">WEBSITES</span></span>
      <span class="hero-word"><span class="hero-word-inner">THAT</span></span>
      <span class="hero-word accent"><span class="hero-word-inner">WORK</span></span>
      <span class="hero-word"><span class="hero-word-inner">AS</span></span>
      <span class="hero-word"><span class="hero-word-inner">HARD</span></span>
      <span class="hero-word"><span class="hero-word-inner">AS</span></span>
      <span class="hero-word"><span class="hero-word-inner">YOU</span></span>
      <span class="hero-word"><span class="hero-word-inner">DO</span></span>
    </h1>
    <p class="hero-sub">Design-led websites without the agency headaches. No surprise fees, no week-long waits for simple changes. Just a designer with almost two decades of experience, building sites that actually work.</p>
    <div class="hero-ctas">
      <a href="#portfolio" class="btn btn-primary">See My Work</a>
      <a href="https://wa.me/442381112819" class="btn btn-outline" target="_blank" rel="noopener">WhatsApp Me</a>
    </div>
  </div>
  <div class="hero-scroll-indicator" aria-hidden="true">
    <div class="hero-scroll-line"></div>
  </div>
</section>

<div class="page-content" id="page-content">
<!-- === ABOUT === -->
<section class="about section dark-section" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="about-grid">
      <div class="about-image reveal-left">
        <div class="about-image-wrapper" id="about-image-wrapper">
          <picture>
            <source media="(max-width: 768px)" srcset="/images/ryan-stanikk-square.jpg" />
            <img src="/images/ryan-stanikk.jpg" alt="Ryan - Web Designer in Southampton, Hampshire, with almost two decades of graphic design experience" loading="lazy" />
          </picture>
          <video src="/images/ryan-stanikk.mp4" id="profile-video" muted playsinline preload="metadata" aria-label="Ryan introduction video"></video>
        </div>
      </div>
      <div class="about-text reveal-right">
        <span class="about-label">About Me</span>
        <h2 id="about-heading">I build websites the way I shoot photos. <span class="accent">With purpose.</span></h2>
        <p>I'm Ryan, a designer and <a href="https://ryanstanikk.co.uk" target="_blank" rel="noopener">commercial photographer</a> with almost two decades of experience in design and marketing, now channelling that expertise into building bespoke websites for businesses that deserve better than what agencies offer.</p>
        <p>In Japanese cooking, kombu is the ingredient you never see. The quiet foundation that makes everything around it better. That's how I approach web design. I've spent years understanding what makes visuals work commercially, not just aesthetically. Every website I build has to look stunning, but more importantly, it has to perform.</p>
        <p>Too many businesses are stuck paying agencies a fortune for basic changes, waiting days for a text update, and dealing with account managers who've never opened a design tool. I'm a one-person studio. You talk directly to the person designing and building your site. Changes happen fast. There are no layers, no bloated invoices for a five-minute job, and no disappearing act after launch.</p>
        <p>Based in Southampton, available across the UK. If you're local, I'll come to you in person. If you're further afield, I'm a video call away.</p>
        <div class="about-stats">
          <div class="stat">
            <span class="stat-number">17+</span>
            <span class="stat-label">Years in Design</span>
          </div>
          <div class="stat">
            <span class="stat-number">10</span>
            <span class="stat-label">Live Projects</span>
          </div>
          <div class="stat">
            <span class="stat-number">UK</span>
            <span class="stat-label">Wide Service</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- === CLIENTS — quiet validation band, infinite marquee === -->
<section class="clients dark-section" id="clients" aria-labelledby="clients-heading">
  <h2 class="clients-eyebrow reveal" id="clients-heading">
    <span class="clients-eyebrow-rule" aria-hidden="true"></span>
    <span>Currently working with</span>
    <span class="clients-eyebrow-rule" aria-hidden="true"></span>
  </h2>
  <div class="clients-marquee" role="region" aria-label="Current clients">
    <div class="clients-track">
      <ul class="clients-set">
        <li class="clients-item"><img src="/images/clients/soleto.png" alt="Soleto" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/padharo.svg" alt="Padharo" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/banana-wharf.png" alt="Banana Wharf" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/the-grand.png" alt="The Grand" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/kesarum.png" alt="Kesarum" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/ryan-stanikk-photography.png" alt="Ryan Stanikk Photography" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/ark-angels.svg" alt="Ark Angels" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/ennios.png" alt="Ennios" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/mustang-group.png" alt="Mustang Group" loading="lazy" /></li>
      </ul>
      <ul class="clients-set" aria-hidden="true">
        <li class="clients-item"><img src="/images/clients/soleto.png" alt="" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/padharo.svg" alt="" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/banana-wharf.png" alt="" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/the-grand.png" alt="" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/kesarum.png" alt="" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/ryan-stanikk-photography.png" alt="" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/ark-angels.svg" alt="" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/ennios.png" alt="" loading="lazy" /></li>
        <li class="clients-item"><img src="/images/clients/mustang-group.png" alt="" loading="lazy" /></li>
      </ul>
    </div>
  </div>
</section>

<!-- === PORTFOLIO === -->
<section class="portfolio section terracotta-section" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="container">
    <div class="section-header">
      <h2 class="blur-reveal" id="portfolio-heading">My Work</h2>
      <a href="#contact" class="section-link reveal">Get Yours Built <span aria-hidden="true">&rarr;</span></a>
    </div>
    <p class="portfolio-intro reveal">Every project is designed to help a business grow. Here is a look at some of the websites I have crafted that drive results and make brands shine.</p>

    <!-- 3-column portfolio grid -->
    <div class="portfolio-columns" id="portfolio-columns">
      <div class="portfolio-col" id="project-1">
        <a href="https://soleto-website.pages.dev" target="_blank" rel="noopener" class="project-browser-link">
          <div class="project-browser reveal">
            <div class="browser-chrome" aria-hidden="true">
              <div class="browser-dots"><span></span><span></span><span></span></div>
              <div class="browser-title">Soleto</div>
            </div>
            <div class="browser-viewport" data-site="https://soleto-website.pages.dev">
              <div class="browser-stack">
                <img src="/images/portfolio/soleto.jpg" alt="Soleto Italian Restaurant - bespoke website design with dark theme, gallery and private dining pages" loading="lazy" class="browser-poster" />
              </div>
            </div>
          </div>
        </a>
        <div class="project-info reveal">
          <h3><a href="https://soleto-website.pages.dev" target="_blank" rel="noopener" class="project-title-link">Soleto</a></h3>
          <p>An Italian restaurant that needed somewhere to send people before they arrived. Menu, gallery, table bookings, all without ringing the kitchen mid-service. <a href="https://soleto-website.pages.dev" target="_blank" rel="noopener" class="project-inline-link">Visit site</a></p>
          <a href="https://soleto-website.pages.dev" target="_blank" rel="noopener" class="btn btn-outline btn-sm project-btn" aria-label="Visit Soleto website">Visit Site <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>

      <div class="portfolio-col" id="project-2">
        <a href="https://ark-angels-cardover.pages.dev" target="_blank" rel="noopener" class="project-browser-link">
          <div class="project-browser reveal">
            <div class="browser-chrome" aria-hidden="true">
              <div class="browser-dots"><span></span><span></span><span></span></div>
              <div class="browser-title">Ark Angels</div>
            </div>
            <div class="browser-viewport" data-site="https://ark-angels-cardover.pages.dev">
              <div class="browser-stack">
                <img src="/images/portfolio/ark-angels.jpg" alt="Ark Angels community platform - vibrant website design with event listings and bold layout" loading="lazy" class="browser-poster" />
              </div>
            </div>
          </div>
        </a>
        <div class="project-info reveal">
          <h3><a href="https://ark-angels-cardover.pages.dev" target="_blank" rel="noopener" class="project-title-link">Ark Angels</a></h3>
          <p>A community music platform with a lot to fit on one page. Gigs, bands, what's on this week, where to find them. None of it cramped. <a href="https://ark-angels-cardover.pages.dev" target="_blank" rel="noopener" class="project-inline-link">Visit site</a></p>
          <a href="https://ark-angels-cardover.pages.dev" target="_blank" rel="noopener" class="btn btn-outline btn-sm project-btn" aria-label="Visit Ark Angels website">Visit Site <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>

      <div class="portfolio-col" id="project-3">
        <a href="https://www.padharo.co.uk" target="_blank" rel="noopener" class="project-browser-link">
          <div class="project-browser reveal">
            <div class="browser-chrome" aria-hidden="true">
              <div class="browser-dots"><span></span><span></span><span></span></div>
              <div class="browser-title">Padharo</div>
            </div>
            <div class="browser-viewport" data-site="https://www.padharo.co.uk">
              <div class="browser-stack">
                <img src="/images/portfolio/padharo.jpg" alt="Padharo vegetarian Indian restaurant - award-winning website with reservation system and menus" loading="lazy" class="browser-poster" />
              </div>
            </div>
          </div>
        </a>
        <div class="project-info reveal">
          <h3><a href="https://www.padharo.co.uk" target="_blank" rel="noopener" class="project-title-link">Padharo</a></h3>
          <p>An award-winning vegetarian Indian restaurant. The food is careful, so the site had to be too. Reservations, menus, and enough room for the photography to do its work. <a href="https://www.padharo.co.uk" target="_blank" rel="noopener" class="project-inline-link">Visit site</a></p>
          <a href="https://www.padharo.co.uk" target="_blank" rel="noopener" class="btn btn-outline btn-sm project-btn" aria-label="Visit Padharo website">Visit Site <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- === SERVICES === -->
<section class="services section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="section-header">
      <h2 class="blur-reveal" id="services-heading">What I Do</h2>
    </div>

    <div class="services-grid">
      <div class="service-card reveal">
        <div class="service-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <span class="service-badge">Design</span>
        <h3>Web Design</h3>
        <p>Bespoke websites built around your business, not around a template. Most developers build functional sites. I build beautiful ones, with the eye of a graphic designer, without the agency price tag or the agency runaround. You deal directly with me, a designer first, not a project manager reading from a script.</p>
        <ul class="service-list">
          <li>Custom design</li>
          <li>Mobile-first</li>
          <li>Built to convert</li>
          <li>SEO foundations</li>
        </ul>
        <a href="#contact" class="btn-card" aria-label="Get started with Web Design">Get Started</a>
      </div>

      <div class="service-card reveal">
        <div class="service-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="12" y1="2" x2="12" y2="22"/></svg>
        </div>
        <span class="service-badge">Development</span>
        <h3>Web Apps</h3>
        <p>More than just websites. I build functional web applications with the features your business needs, from content management to bespoke tools.</p>
        <ul class="service-list">
          <li>Custom web apps</li>
          <li>CMS integration</li>
          <li>Interactive features</li>
          <li>Performance-first</li>
        </ul>
        <a href="#contact" class="btn-card" aria-label="Get started with Web Apps">Get Started</a>
      </div>

      <div class="service-card reveal">
        <div class="service-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <span class="service-badge">Infrastructure</span>
        <h3>Hosting & Domains</h3>
        <p>I handle the technical side so you do not have to. Domain registration, hosting setup, SSL certificates, and ongoing maintenance all taken care of.</p>
        <ul class="service-list">
          <li>Domain registration</li>
          <li>Fast, secure hosting</li>
          <li>SSL certificates</li>
          <li>Ongoing support</li>
        </ul>
        <a href="#contact" class="btn-card" aria-label="Get started with Hosting and Domains">Get Started</a>
      </div>

      <div class="service-card reveal">
        <div class="service-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </div>
        <span class="service-badge">Content</span>
        <h3>Content Management</h3>
        <p>Tired of being charged a fortune for a text change? Send it over and I will handle it, usually the same day. Simple updates like text, images, and menu changes are always included. No sneaky invoices. If you prefer to manage content yourself, I can build a CMS into your site too.</p>
        <ul class="service-list">
          <li>Quick turnaround updates</li>
          <li>Optional CMS</li>
          <li>No lock-in</li>
          <li>Full control</li>
        </ul>
        <a href="#contact" class="btn-card" aria-label="Get started with Content Management">Get Started</a>
      </div>
    </div>
  </div>
</section>

<!-- === PRICING === -->
<section class="pricing section" id="pricing" aria-labelledby="pricing-heading">
  <div class="container">
    <div class="section-header pricing-header">
      <h2 class="blur-reveal" id="pricing-heading">Investment</h2>
      <div class="pricing-toggle-wrap reveal">
      <span class="pricing-toggle-label" id="toggle-label-monthly">Monthly</span>
      <button class="pricing-toggle" id="pricing-toggle" role="switch" aria-checked="false" aria-label="Switch between monthly and pay upfront pricing">
        <span class="pricing-toggle-thumb"></span>
      </button>
      <span class="pricing-toggle-label" id="toggle-label-oneoff">Pay Upfront</span>
      </div>
    </div>

    <div class="pricing-grid">
      <div class="pricing-card reveal" data-tier="starter">
        <div class="pricing-card-inner">
          <span class="pricing-tier">Starter</span>
          <p class="pricing-desc">A single-page site that makes you look as good online as you are in person.</p>
          <div class="pricing-amount">
            <span class="pricing-currency">&pound;</span>
            <span class="pricing-value" data-monthly="49" data-upfront="199">49</span>
            <span class="pricing-period">/mo</span>
          </div>
