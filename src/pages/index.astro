        const n10 = dot(grad3[perm[X+1+perm[Y]]%12], x-1, y);
        const n11 = dot(grad3[perm[X+1+perm[Y+1]]%12], x-1, y-1);
        return lerp(lerp(n00,n10,u), lerp(n01,n11,u), v);
      }

      function setupWaves() {
        const rect = hero!.getBoundingClientRect();
        wavesCanvas.width = rect.width;
        wavesCanvas.height = rect.height;
        wState.lines = [];
        const gx = 12, gy = 32, ow = rect.width + 200, oh = rect.height + 30;
        const totalLines = Math.ceil(ow / gx);
        const totalPts = Math.ceil(oh / gy);
        const xs = (rect.width - gx * totalLines) / 2;
        const ys = (rect.height - gy * totalPts) / 2;
        for (let i = 0; i <= totalLines; i++) {
          const pts: any[] = [];
          for (let j = 0; j <= totalPts; j++) {
            pts.push({ x: xs + gx*i, y: ys + gy*j, wx: 0, wy: 0, cx: 0, cy: 0, cvx: 0, cvy: 0 });
          }
          wState.lines.push(pts);
        }
      }

      function tickWaves(time: number) {
        const m = wState.mouse;
        m.sx += (m.x - m.sx) * 0.1;
        m.sy += (m.y - m.sy) * 0.1;
        const dx = m.sx - m.lx, dy = m.sy - m.ly;
        m.v = Math.hypot(dx, dy);
        m.vs += (m.v - m.vs) * 0.1;
        m.vs = Math.min(100, m.vs);
        m.a = Math.atan2(dy, dx);
        m.lx = m.sx; m.ly = m.sy;

        wState.lines.forEach(pts => {
          pts.forEach(p => {
            const nx = (p.x + time * 0.0125) * 0.002;
            const ny = (p.y + time * 0.005) * 0.0015;
            const mv = perlin2(nx, ny) * 12;
            p.wx = Math.cos(mv) * 32;
            p.wy = Math.sin(mv) * 16;

            const pdx = p.x - m.sx, pdy = p.y - m.sy;
            const d = Math.hypot(pdx, pdy);
            const ir = Math.max(175, m.vs);
            if (d < ir) {
              const fo = 1 - d/ir;
              const f = Math.cos(d * 0.001) * fo;
              const ff = f * ir * m.vs * 0.00065;
              p.cvx += Math.cos(m.a) * ff;
              p.cvy += Math.sin(m.a) * ff;
            }
            p.cvx += (0 - p.cx) * 0.005;
            p.cvy += (0 - p.cy) * 0.005;
            p.cvx *= 0.925; p.cvy *= 0.925;
            p.cx += p.cvx * 2; p.cy += p.cvy * 2;
            p.cx = Math.max(-100, Math.min(100, p.cx));
            p.cy = Math.max(-100, Math.min(100, p.cy));
          });
        });

        wCtx.clearRect(0, 0, wavesCanvas.width, wavesCanvas.height);
        wCtx.beginPath();
        wCtx.strokeStyle = '#D4714E';
        wCtx.lineWidth = 0.5;
        wState.lines.forEach(pts => {
          const p0 = pts[0];
          wCtx.moveTo(Math.round((p0.x + p0.wx)*10)/10, Math.round((p0.y + p0.wy)*10)/10);
          for (let i = 0; i < pts.length - 1; i++) {
            const c = pts[i], n = pts[i+1];
            const cx = c.x + c.wx + c.cx, cy = c.y + c.wy + c.cy;
            const nx2 = n.x + n.wx + n.cx, ny2 = n.y + n.wy + n.cy;
            wCtx.quadraticCurveTo(Math.round(cx*10)/10, Math.round(cy*10)/10, Math.round((cx+nx2)/2*10)/10, Math.round((cy+ny2)/2*10)/10);
          }
        });
        wCtx.stroke();
        requestAnimationFrame(tickWaves);
      }

      setupWaves();
      requestAnimationFrame(tickWaves);
      window.addEventListener('resize', setupWaves);

      // On touch/mobile devices, auto-drift a virtual cursor slowly across the canvas
      const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
      if (isTouchDevice) {
        const rect = hero.getBoundingClientRect();
        const cx = rect.width / 2, cy = rect.height / 2;
        wState.mouse.x = cx; wState.mouse.y = cy;
        wState.mouse.sx = cx; wState.mouse.sy = cy;
        wState.mouse.lx = cx; wState.mouse.ly = cy;
        wState.mouse.set = true;
        wState.mouse.vs = 12;

        let autoAngle = 0;
        function autoDrift() {
          autoAngle += 0.004;
          const r = hero!.getBoundingClientRect();
          const ax = r.width * 0.5 + Math.cos(autoAngle) * r.width * 0.3 + Math.sin(autoAngle * 0.7) * r.width * 0.1;
          const ay = r.height * 0.5 + Math.sin(autoAngle * 0.6) * r.height * 0.25;
          wState.mouse.x = ax;
          wState.mouse.y = ay;
          wState.mouse.vs = 10 + Math.sin(autoAngle * 1.3) * 5;
          requestAnimationFrame(autoDrift);
        }
        requestAnimationFrame(autoDrift);
      } else {
        hero.addEventListener('mousemove', (e) => {
          const rect = hero!.getBoundingClientRect();
          const mx = e.clientX - rect.left, my = e.clientY - rect.top;
          wState.mouse.x = mx; wState.mouse.y = my;
          if (!wState.mouse.set) {
            wState.mouse.sx = mx; wState.mouse.sy = my;
            wState.mouse.lx = mx; wState.mouse.ly = my;
            wState.mouse.set = true;
          }
        });
      }
    }

    // Nav scroll — hide on down, show on up
    const nav = document.getElementById('nav');
    let lastScrollY = 0;
    let scrollThreshold = 5;
    window.addEventListener('scroll', () => {
      const currentY = window.scrollY;
      if (currentY > 50) {
        nav?.classList.add('scrolled');
      } else {
        nav?.classList.remove('scrolled');
        nav?.classList.remove('nav-hidden');
      }
      // Only hide/show after scrolling past hero area
      if (currentY > 200) {
        if (currentY - lastScrollY > scrollThreshold) {
          nav?.classList.add('nav-hidden');
        } else if (lastScrollY - currentY > scrollThreshold) {
          nav?.classList.remove('nav-hidden');
        }
      }
      lastScrollY = currentY;
    });

    // Mobile menu
    const navToggle = document.getElementById('nav-toggle');
    const navLinks = document.getElementById('nav-links');

    navToggle?.addEventListener('click', () => {
      navLinks?.classList.toggle('active');
      navToggle.classList.toggle('active');
    });

    navLinks?.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('active');
        navToggle?.classList.remove('active');
      });
    });

    // Profile video hover (desktop) / scroll auto-play (mobile)
    const profileWrapper = document.getElementById('about-image-wrapper');
    const profileVideo = document.getElementById('profile-video');
    if (profileWrapper && profileVideo) {
      const isMobile = window.matchMedia('(max-width: 768px)').matches;
      let videoHasPlayed = false;

      function onVideoEnd() {
        profileWrapper.classList.remove('video-playing');
        profileVideo.currentTime = 0;
        videoHasPlayed = true;
      }

      profileVideo.addEventListener('ended', onVideoEnd);

      if (!isMobile) {
        // Desktop: play on hover, switch back when done, allow re-hover
        profileWrapper.addEventListener('mouseenter', () => {
          profileVideo.currentTime = 0;
          profileVideo.play();
          profileWrapper.classList.add('video-playing');
        });

        profileWrapper.addEventListener('mouseleave', () => {
          // If video is still playing when mouse leaves, let it finish
          // but if they leave we should stop and reset
          profileVideo.pause();
          profileWrapper.classList.remove('video-playing');
          profileVideo.currentTime = 0;
        });
      } else {
        // Mobile: auto-play once when 1/3 up the viewport
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !videoHasPlayed) {
              videoHasPlayed = true;
              profileVideo.currentTime = 0;
              profileVideo.play();
              profileWrapper.classList.add('video-playing');
              observer.disconnect();
            }
          });
        }, {
          threshold: 0.5,
          rootMargin: '0px 0px -33% 0px'
        });
        observer.observe(profileWrapper);
      }
    }

    // Portfolio auto-scroll
    const viewports = document.querySelectorAll('.browser-viewport');
    const isMobilePort = window.matchMedia('(max-width: 768px)').matches;
    const maxSpeed = 1.0; // pixels per frame at full speed
    const rampDuration = 120; // frames to reach full speed (~2 seconds)

    viewports.forEach(viewport => {
      const img = viewport.querySelector('img');
      if (!img) return;

      let animId = null;
      let frameCount = 0;
      let hasCompleted = false;

      function startScroll() {
        if (animId) return;
        if (isMobilePort && hasCompleted) return;
        const maxScroll = img.offsetHeight - viewport.offsetHeight;
        if (maxScroll <= 0) return;
        frameCount = 0;

        function step() {
          frameCount++;
          const progress = Math.min(frameCount / rampDuration, 1);
          const speed = maxSpeed * (progress * progress);

          const currentTop = parseFloat(img.style.top || '0');
          const newTop = currentTop - speed;
          if (Math.abs(newTop) >= maxScroll) {
            img.style.top = -maxScroll + 'px';
            animId = null;
            if (isMobilePort) {
              // Mobile: snap back to top after reaching bottom, don't scroll again
              hasCompleted = true;
              setTimeout(() => {
                img.style.transition = 'top 0.6s ease-out';
                img.style.top = '0px';
              }, 800);
            }
            return;
          }
          img.style.top = newTop + 'px';
          animId = requestAnimationFrame(step);
        }
        img.style.transition = 'none';
        animId = requestAnimationFrame(step);
      }

      function stopScroll() {
        if (animId) {
          cancelAnimationFrame(animId);
          animId = null;
        }
        img.style.transition = 'top 0.6s ease-out';
        img.style.top = '0px';
      }

      if (!isMobilePort) {
        // Desktop: hover to scroll, leave to reset
        viewport.closest('.project-browser').addEventListener('mouseenter', startScroll);
        viewport.closest('.project-browser').addEventListener('mouseleave', stopScroll);
      }

      // Store functions on the element for mobile use
      viewport._startScroll = startScroll;
      viewport._stopScroll = stopScroll;
    });

    // Mobile: only one scrolls at a time
    if (isMobilePort) {
      let activeViewport = null;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            // Stop the currently active one first
            if (activeViewport && activeViewport !== entry.target) {
              activeViewport._stopScroll();
            }
            activeViewport = entry.target;
            entry.target._startScroll();
          } else {
            entry.target._stopScroll();
            if (activeViewport === entry.target) {
              activeViewport = null;
            }
          }
        });
      }, {
        threshold: 0.3
      });

      viewports.forEach(vp => observer.observe(vp));
    }

    // FAQ
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const isActive = item?.classList.contains('active');

        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
        document.querySelectorAll('.faq-question').forEach(q => q.setAttribute('aria-expanded', 'false'));

        if (!isActive && item) {
          item.classList.add('active');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Pricing toggle
    const pricingToggle = document.getElementById('pricing-toggle');
    const labelMonthly = document.getElementById('toggle-label-monthly');
    const labelOneoff = document.getElementById('toggle-label-oneoff');
    const priceValues = document.querySelectorAll('.pricing-value');
    const pricePeriods = document.querySelectorAll('.pricing-period');
    const priceCommitments = document.querySelectorAll('.pricing-commitment');
    const priceRenewals = document.querySelectorAll('.pricing-renewal');

    if (labelMonthly) labelMonthly.classList.add('active');

    pricingToggle?.addEventListener('click', () => {
      const isUpfront = pricingToggle.getAttribute('aria-checked') === 'true';
      pricingToggle.setAttribute('aria-checked', String(!isUpfront));

      if (!isUpfront) {
        // Switching to pay upfront
        labelOneoff?.classList.add('active');
        labelMonthly?.classList.remove('active');
        priceValues.forEach(el => {
          el.style.opacity = '0';
          setTimeout(() => {
            el.textContent = el.dataset.upfront;
            el.style.opacity = '1';
          }, 150);
        });
        pricePeriods.forEach(el => el.style.display = 'none');
        priceCommitments.forEach(el => el.textContent = 'One-off build fee');
        const retainerRates = ['29', '49', '99'];
        priceRenewals.forEach((el, i) => el.textContent = 'Then \u00A3' + retainerRates[i] + '/mo');
      } else {
        // Switching to monthly
        labelMonthly?.classList.add('active');
        labelOneoff?.classList.remove('active');
        priceValues.forEach(el => {
          el.style.opacity = '0';
          setTimeout(() => {
            el.textContent = el.dataset.monthly;
            el.style.opacity = '1';
          }, 150);
        });
        pricePeriods.forEach(el => el.style.display = '');
        priceCommitments.forEach(el => el.textContent = '12-month commitment');
        const renewalRates = ['29', '49', '99'];
        priceRenewals.forEach((el, i) => el.textContent = 'Then \u00A3' + renewalRates[i] + '/mo');
      }
    });

    // Audit form
    const auditForm = document.getElementById('audit-form');
    const auditSuccess = document.getElementById('audit-success');
    auditForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      const url = document.getElementById('audit-url')?.value;
      if (!url) return;

      // Open WhatsApp with the URL pre-filled
      const message = encodeURIComponent('Hi Ryan, I would like a free website review for: ' + url);
      window.open('https://wa.me/442381112819?text=' + message, '_blank');

      // Show success state
      auditForm.hidden = true;
      if (auditSuccess) auditSuccess.hidden = false;
    });

    // Smooth scroll via Lenis
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const href = anchor.getAttribute('href');
        if (!href || href === '#') return;
        const target = document.querySelector(href);
        if (target) {
          // @ts-ignore
          window.__lenis.scrollTo(target, { offset: -80 });
        }
      });
    });

    function initAnimations() {
      // Hero card-over: pin hero, page content scrolls over it
      // @ts-ignore
      ScrollTrigger.create({
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        pin: true,
        pinSpacing: false
      });

      // Hero entrance - character blur reveal
      // @ts-ignore
      const heroTl = gsap.timeline();

      // Split each word into characters and collect all char spans
      const wordInners = document.querySelectorAll('.hero-word-inner');
      const allChars: HTMLSpanElement[] = [];
      wordInners.forEach(word => {
        // Reset the slide-up transform so word is in position
        (word as HTMLElement).style.transform = 'translateY(0)';
        const chars = splitChars(word);
        allChars.push(...chars);
      });

      // @ts-ignore
      heroTl.to(allChars, {
        opacity: 1,
        filter: 'blur(0px)',
        duration: 0.6,
        ease: 'power4.out',
        stagger: 0.025,
      }, 0);

      // Subtitle and CTAs fade in after character reveal
      const charRevealDuration = 0.6 + (allChars.length * 0.025);
      heroTl
        // @ts-ignore
        .to('.hero-sub', { opacity: 1, y: 0, duration: 0.8, ease: 'back.out(1.4)' }, charRevealDuration * 0.6)
        // @ts-ignore
        .to('.hero-ctas', { opacity: 1, y: 0, duration: 0.8, ease: 'back.out(1.4)' }, charRevealDuration * 0.7)
        // @ts-ignore
        .to('.hero-scroll-indicator', { opacity: 1, duration: 0.6 }, charRevealDuration * 0.85);

      // Section heading blur-reveal on scroll
      document.querySelectorAll('.blur-reveal').forEach(heading => {
        const chars = splitChars(heading);
        // @ts-ignore
        gsap.to(chars, {
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.5,
          ease: 'power3.out',
          stagger: 0.02,
          scrollTrigger: {
            trigger: heading,
            start: 'top 85%',
            toggleActions: 'play none none none'
          }
        });
      });

      // Scroll reveals (scale + spring easing)
      // @ts-ignore
      gsap.utils.toArray('.reveal').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, y: 30, scale: 0.97 },
          {
            opacity: 1, y: 0, scale: 1,
            duration: 0.8,
            ease: 'back.out(1.4)',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // @ts-ignore
      gsap.utils.toArray('.reveal-left').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, x: -40, scale: 0.97 },
          {
            opacity: 1, x: 0, scale: 1,
            duration: 0.8,
            ease: 'back.out(1.4)',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // @ts-ignore
      gsap.utils.toArray('.reveal-right').forEach((el: Element) => {
        // @ts-ignore
        gsap.fromTo(el,
          { opacity: 0, x: 40, scale: 0.97 },
          {
            opacity: 1, x: 0, scale: 1,
            duration: 0.8,
            ease: 'back.out(1.4)',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none'
            }
          }
        );
      });

      // Staggered service cards
      // @ts-ignore
      gsap.fromTo('.service-card',
        { autoAlpha: 0, y: 40, scale: 0.97 },
        {
          autoAlpha: 1, y: 0, scale: 1,
          duration: 0.6,
          stagger: 0.15,
          ease: 'back.out(1.4)',
          scrollTrigger: {
            trigger: '.services-grid',
            start: 'top 80%'
          },
          onComplete: function() {
            document.querySelectorAll('.service-card').forEach(function(el) { el.classList.add('gsap-revealed'); });
          }
        }
      );

      // Pricing cards
      // @ts-ignore
      gsap.fromTo('.pricing-card',
        { autoAlpha: 0, y: 40, scale: 0.97 },
        {
          autoAlpha: 1, y: 0, scale: 1,
          duration: 0.6,
          stagger: 0.15,
          ease: 'back.out(1.4)',
          scrollTrigger: {
            trigger: '.pricing-grid',
            start: 'top 80%'
          },
          onComplete: function() {
            document.querySelectorAll('.pricing-card').forEach(function(el) { el.classList.add('gsap-revealed'); });
          }
        }
      );

      // Process steps
      // @ts-ignore
      gsap.fromTo('.process-step',
        { autoAlpha: 0, x: -30, scale: 0.97 },
        {
          autoAlpha: 1, x: 0, scale: 1,
          duration: 0.6,
          stagger: 0.2,
          ease: 'back.out(1.4)',
          scrollTrigger: {
            trigger: '.process-grid',
            start: 'top 80%'
          }
        }
      );

      // Process lines
      // @ts-ignore
      gsap.fromTo('.process-line',
        { autoAlpha: 0, scaleY: 0 },
        {
          autoAlpha: 1, scaleY: 1,
          duration: 0.4,
          stagger: 0.2,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.process-grid',
            start: 'top 80%'
          }
        }
      );

      // Parallax on hero waves canvas
      const wavesEl = document.getElementById('hero-waves');
      if (wavesEl) {
        // @ts-ignore
        gsap.to(wavesEl, {
          yPercent: 30,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom top',
            scrub: true
          }
        });
      }
    }
  }

  initSite();
</script>
